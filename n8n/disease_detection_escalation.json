{
  "name": "KisanAlert_Disease_Escalation_Telegram",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "kisan-alert/disease-escalation",
        "options": {}
      },
      "id": "node_webhook",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.severity}}",
              "value2": "HIGH"
            }
          ]
        }
      },
      "id": "node_check_severity",
      "name": "Is Severity High?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [280, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{$env.TELEGRAM_BOT_TOKEN}}/sendMessage",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"chat_id\": \"{{$env.TELEGRAM_CHAT_ID}}\", \"text\": \"⚠️ High Severity Crop Disease Escalation! Farmer: {{$json.farmerName}} has a suspected case of: {{$json.diseaseName}}. Please review immediately: http://localhost:3000/dashboard/expert\"}",
        "options": {}
      },
      "id": "node_telegram_expert",
      "name": "Notify Expert (Telegram)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [500, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{$env.TELEGRAM_BOT_TOKEN}}/sendMessage",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"chat_id\": \"{{$env.TELEGRAM_CHAT_ID}}\", \"text\": \"🌱 Kisan Alert: Your crop concern ({{$json.diseaseName}}) has been escalated to an RSK expert. Status check: http://localhost:3000/dashboard/farmer\"}",
        "options": {}
      },
      "id": "node_telegram_farmer",
      "name": "Notify Farmer (Telegram)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [500, 400]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          {
            "node": "Is Severity High?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is Severity High?": {
      "main": [
        [
          {
            "node": "Notify Expert (Telegram)",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Notify Farmer (Telegram)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
